# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/story_translation

# Supabase (lấy từ: Project Settings → Database → Connection string → URI)
# Dùng "Transaction pooler" (port 6543) nếu deploy serverless, hoặc "Direct" (port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

GEMINI_API_KEY=
CORS_ORIGINS=http://localhost:3000
